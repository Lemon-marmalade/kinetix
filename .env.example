# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# MOCK_AI_COACH: Optional. When set to true, /api/coaching skips Gemini and
# returns deterministic local coaching text so the UI can be tested offline or
# while rate-limited.
MOCK_AI_COACH="false"

# ELEVENLABS_API_KEY: Required for ElevenLabs voice synthesis.
# Keep this server-side when possible. The app currently accepts
# NEXT_PUBLIC_ELEVENLABS_API_KEY as a legacy fallback.
ELEVENLABS_API_KEY="MY_ELEVENLABS_API_KEY"

# ELEVENLABS_VOICE_ID: Optional custom voice. Defaults to the built-in voice
# when omitted.
ELEVENLABS_VOICE_ID="MY_ELEVENLABS_VOICE_ID"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"
